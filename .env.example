# ── AI Assistant Server ───────────────────────────────────────────────────────
# Required: Your Anthropic API key (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Override the default model (default: claude-sonnet-4-6)
ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional: WebSocket server port (default: 8765)
PORT=8765


# ── Google Connector ──────────────────────────────────────────────────────────
# OAuth2 access token (required). Obtain via Google OAuth2 flow.
GOOGLE_ACCESS_TOKEN=ya29...

# For automatic token refresh (all three required together):
GOOGLE_REFRESH_TOKEN=1//...
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...


# ── GitHub Connector ──────────────────────────────────────────────────────────
# Personal access token or fine-grained token with repo/issues scope
GITHUB_TOKEN=ghp_...


# ── Slack Connector ───────────────────────────────────────────────────────────
# Bot OAuth token from your Slack app (xoxb-...)
SLACK_TOKEN=xoxb-...


# ── Notion Connector ──────────────────────────────────────────────────────────
# Integration secret from https://www.notion.so/my-integrations
NOTION_TOKEN=secret_...


# ── Jira Connector ───────────────────────────────────────────────────────────
# Your Atlassian Cloud hostname (without https://)
JIRA_HOST=yourorg.atlassian.net
# Email associated with your Atlassian account
JIRA_EMAIL=you@example.com
# API token from https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=ATATTxxxxxxx


# ── AidWatch Server ───────────────────────────────────────────────────────────
# Port for the AidWatch Express API (default: 3000)
AIDWATCH_PORT=3000

# Allowed CORS origin (default: * in development — restrict in production)
CORS_ORIGIN=http://localhost:3000
